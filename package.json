{
  "name": "vscode-pi-model-chat-provider",
  "displayName": "Pi Language Model Provider",
  "description": "Use Pi coding agent as a language model provider in VS Code",
  "version": "0.1.0",
  "publisher": "pi-model-provider",
  "type": "module",
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "ai",
    "language-model",
    "pi",
    "chat",
    "copilot"
  ],
  "activationEvents": [
    "onLanguageModelChatProvider:pi"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "pi",
        "displayName": "Pi Coding Agent",
        "managementCommand": "pi.configure"
      }
    ],
    "commands": [
      {
        "command": "pi.configure",
        "title": "Pi: Configure API Keys & Settings"
      }
    ],
    "configuration": {
      "title": "Pi Agent",
      "properties": {
        "pi.binaryPath": {
          "type": "string",
          "default": "pi",
          "description": "Path to the Pi CLI binary (default: 'pi' from PATH)"
        },
        "pi.workingDirectory": {
          "type": "string",
          "default": "",
          "description": "Working directory for Pi agent (default: workspace root)"
        },
        "pi.autoRestart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically restart Pi agent on crash"
        },
        "pi.maxRestartAttempts": {
          "type": "number",
          "default": 3,
          "description": "Maximum number of restart attempts before giving up"
        },
        "pi.toolCallDisplay": {
          "type": "string",
          "default": "text",
          "enum": ["text", "hidden"],
          "enumDescriptions": [
            "Show tool execution as text annotations",
            "Hide tool execution details"
          ],
          "description": "How to display Pi's tool execution in chat"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.52.0"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.103.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.3.0"
  }
}
