{
  "name": "vscode-pi-model-chat-provider",
  "displayName": "Pi Coding Agent - Language Model Provider",
  "description": "Use Pi Coding Agent directly from Copilot Chat via VS Code's Language Model Provider API",
  "version": "0.1.2",
  "publisher": "tintinweb",
  "preview": true,
  "icon": "images/pi-logo-black.png",
  "author": {
    "name": "tintinweb"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tintinweb/vscode-pi-model-chat-provider.git"
  },
  "bugs": {
    "url": "https://github.com/tintinweb/vscode-pi-model-chat-provider/issues"
  },
  "homepage": "https://github.com/tintinweb/vscode-pi-model-chat-provider#readme",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "type": "module",
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "pi",
    "pi-coding-agent",
    "coding-agent",
    "autonomous-agent",
    "language-model",
    "language-model-provider",
    "ai",
    "chat",
    "copilot",
    "vscode-lm"
  ],
  "activationEvents": [
    "onLanguageModelChatProvider:pi"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "icons": {
      "pi-logo": {
        "description": "Pi logo icon",
        "default": {
          "fontPath": "images/pi-logo.woff",
          "fontCharacter": "\\e900"
        }
      }
    },
    "languageModelChatProviders": [
      {
        "vendor": "pi",
        "displayName": "Pi Coding Agent"
      }
    ],
    "configuration": {
      "title": "Pi Agent",
      "properties": {
        "pi.binaryPath": {
          "type": "string",
          "default": "pi",
          "description": "Path to the Pi CLI binary (default: 'pi' from PATH)"
        },
        "pi.workingDirectory": {
          "type": "string",
          "default": "",
          "description": "Working directory for Pi agent (default: workspace root)"
        },
        "pi.autoRestart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically restart Pi agent on crash"
        },
        "pi.maxRestartAttempts": {
          "type": "number",
          "default": 3,
          "description": "Maximum number of restart attempts before giving up"
        },
        "pi.additionalArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional command-line arguments to pass to Pi CLI"
        },
        "pi.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging for Pi extension"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.52.0"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.103.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.3.0"
  }
}
